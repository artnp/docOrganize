@echo off
CHCP 65001 > nul
setlocal enabledelayedexpansion

echo ====================================================
echo      ไอคอนสำหรับ รวมไฟล์ (Merge All to PDF)
echo ====================================================

:: ตรวจสอบว่ามีการลากไฟล์มาไหม
if "%~1"=="" (
    echo [!] วิธีใช้: ลากไฟล์เอกสารหรือ "โฟลเดอร์" มาวางบนไอคอนนี้
    pause
    exit /b
)

echo [*] กำลังเริ่มประมวลผล...
echo [*] กรุณารอสักครู่ หากไฟล์มีจำนวนมากอาจใช้เวลา...
echo ----------------------------------------------------

:: เรียกใช้ Python โดยใช้คำสั่ง python -u เพื่อให้แสดง Log การทำงานทันที
:: ใช้ "%~dp0" เพื่อระบุ path ของสคริปต์ที่อยู่โฟลเดอร์เดียวกับตัว .bat
python -u "%~dp0merge_document.py" %*

if %errorlevel% neq 0 (
    echo.
    echo ----------------------------------------------------
    echo [X] พบข้อผิดพลาดระว่างการทำงาน (Code: %errorlevel%)
) else (
    echo.
    echo ----------------------------------------------------
    echo [+] ทำงานสำเร็จ!
)
